# ── Supabase PostgreSQL ──────────────────────────────────────────
# Copie da página: Supabase → Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[SUA_SENHA]@db.[SEU_REF].supabase.co:5432/postgres

# ── JWT ──────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=mude_isso_para_uma_chave_secreta_longa
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── CORS ─────────────────────────────────────────────────────────
# URL do frontend no Render (ou localhost para desenvolvimento)
FRONTEND_URL=http://localhost:5173

# ── App ──────────────────────────────────────────────────────────
APP_NAME=Tasky
DEBUG=false
